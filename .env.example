# ── Server (server/.env) ──────────────────────────────────────────────────────
SCM820_HOST=192.168.1.100
SCM820_PORT=2202
WS_PORT=8080
WS_HOST=0.0.0.0
USE_MOCK=false

# ── Client (client/.env.development) ─────────────────────────────────────────
# WebSocket URL for the bridge server (leave blank to auto-detect from window.location)
VITE_WS_URL=ws://localhost:8080
# Timestamp format in the debug console: 12h or 24h
VITE_TIME_FORMAT=24h
