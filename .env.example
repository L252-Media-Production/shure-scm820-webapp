# ── Server (server/.env) ──────────────────────────────────────────────────────
SCM820_HOST=192.168.1.100
SCM820_PORT=2202
WS_PORT=8080
WS_HOST=0.0.0.0
USE_MOCK=false

# Behringer X-Touch — server listens for incoming Apple MIDI connections from the X-Touch
# Set your X-Touch to MC slave mode and point it at this server's IP on XTOUCH_PORT.
# Docker: publish with -p 5004:5004/udp -p 5005:5005/udp
XTOUCH_PORT=5004

# ── Client (client/.env.development) ─────────────────────────────────────────
# WebSocket URL for the bridge server (leave blank to auto-detect from window.location)
VITE_WS_URL=ws://localhost:8080
# Timestamp format in the debug console: 12h or 24h
VITE_TIME_FORMAT=24h
